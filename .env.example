# ─────────────────────────────────────────────────────────────────────────────
# Agility Engineers Landing-Page Generator — environment
# Copy to .env.local (dev) or set in your host's env (prod).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (configs + leads live here) ─────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/ae_invitation
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=10000

# ── Site / SEO ───────────────────────────────────────────────────────────────
# Canonical origin used for sitemap, canonical URLs, and absolute OG image URLs.
NEXT_PUBLIC_SITE_URL=https://invitation.agility-engineers.com

# ── Admin auth ───────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-please
# Optional dedicated HMAC signing secret (>=16 chars). Falls back to ADMIN_PASSWORD.
ADMIN_SESSION_SECRET=
# Extra origins allowed past the same-origin CSRF check (comma separated).
ALLOWED_ORIGINS=

# ── AI generation (admin picks Claude OR OpenAI per generation) ───────────────
# Each key independently enables its provider; availableProviders() reports which.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Model overrides (optional)
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_MODEL=gpt-4o
# Image generation is OpenAI-only (Anthropic has no image API); needs OPENAI_API_KEY.
OPENAI_IMAGE_MODEL=gpt-image-1

# ── Image storage (S3 — uploads + AI-generated images) ───────────────────────
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_PREFIX=ae-invitation
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Public base URL for objects (CDN/CloudFront or the bucket's public URL).
# If unset, presigned GET URLs are used.
AWS_S3_PUBLIC_BASE_URL=

# ── Leads → Zapier (outbound webhook; full payload on capture) ───────────────
ZAPIER_WEBHOOK_URL=

# ── Cron secret (sitemap warmers / retry jobs, if used) ──────────────────────
CRON_SECRET=
