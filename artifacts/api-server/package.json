    "express": "^5.2.1",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.10",
    "esbuild": "0.27.3",
